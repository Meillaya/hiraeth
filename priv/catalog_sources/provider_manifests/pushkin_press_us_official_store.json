{
  "provider": "pushkin_press_us_official_store",
  "name": "Pushkin Press US",
  "source_mode": "api",
  "source_urls": [
    "https://us.pushkinpress.com/our-books/",
    "https://us.pushkinpress.com/book",
    "https://us.pushkinpress.com/wp-json"
  ],
  "source_hosts": [
    "us.pushkinpress.com"
  ],
  "cover_hosts": [
    "us.pushkinpress.com"
  ],
  "permission_basis": "Operator-authorized public catalog refresh from official publisher pages/APIs; factual bibliographic metadata, official product descriptions, official cover URLs, purchase links, and source provenance preserved for each field.",
  "takedown_contact": "https://us.pushkinpress.com/contact/",
  "excluded_content": [
    "cart_checkout_account",
    "inventory_state",
    "prices",
    "user_reviews",
    "raw_html_without_sanitization",
    "pushkin_childrens_books",
    "pushkin_press_classics"
  ],
  "cover_cache_policy": "cache_allowed",
  "not_legal_advice": "Operator-authorized ingestion policy and provenance metadata; not legal advice.",
  "api": {
    "type": "wordpress",
    "endpoint": "https://us.pushkinpress.com",
    "auth": null,
    "post_type": "book",
    "taxonomy": "imprint",
    "include_imprints": ["pushkin-press", "pushkin-vertigo", "steerforth"],
    "exclude_imprints": ["pushkin-childrens-books", "pushkin-press-classics"],
    "fetch_detail_pages": true
  },
  "rate_limit": {
    "max_concurrency": 2,
    "min_delay_ms": 250,
    "max_bytes": 104857600
  },
  "expected_record_count": 267
}
