{
  "provider": "deep_vellum_official_store",
  "name": "Deep Vellum",
  "source_mode": "scrape",
  "source_urls": [
    "https://store.deepvellum.org/collections/all"
  ],
  "source_hosts": [
    "store.deepvellum.org"
  ],
  "cover_hosts": [
    "cdn.shopify.com",
    "covers.openlibrary.org"
  ],
  "permission_basis": "Operator-authorized public catalog refresh from official publisher pages/APIs; factual bibliographic metadata, official product descriptions, official cover URLs, purchase links, and source provenance preserved for each field.",
  "takedown_contact": "https://store.deepvellum.org/pages/contact-us",
  "excluded_content": [
    "cart_checkout_account",
    "inventory_state",
    "user_reviews",
    "raw_html_without_sanitization"
  ],
  "cover_cache_policy": "cache_allowed",
  "not_legal_advice": "Operator-authorized ingestion policy and provenance metadata; not legal advice.",
  "spider": {
    "module": "deep_vellum",
    "start_urls": [
      "https://store.deepvellum.org/collections/all"
    ],
    "use_stealthy_fetcher": true,
    "selectors": {
      "item": ".sparq-result-inner",
      "title": ".sparq-item-title::text",
      "publisher": ".vendor-title::text",
      "cover": ".sq-product-image img.item-image::attr(data-src)",
      "description": ".product-single__description.rte::text",
      "publication_date": ".product-single__description.rte::text",
      "isbn": ".product-single__description.rte::text"
    }
  },
  "api": {
    "type": "shopify",
    "endpoint": "https://store.deepvellum.org",
    "auth": null,
    "allowed_vendors": ["Deep Vellum", "Deep Vellum Publishing"]
  },
  "rate_limit": {
    "max_concurrency": 2,
    "min_delay_ms": 250,
    "max_bytes": 15728640
  },
  "expected_record_count": 352
}
