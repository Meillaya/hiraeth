{
    "provider": "and_other_stories_official_store",
    "name": "And Other Stories",
    "source_mode": "api",
    "source_urls": [
        "https://www.andotherstories.org/books/",
        "https://www.andotherstories.org/wp-json/wp/v2/product"
    ],
    "source_hosts": [
        "www.andotherstories.org"
    ],
    "cover_hosts": [
        "www.andotherstories.org"
    ],
    "permission_basis": "Operator-authorized public catalog refresh from official publisher pages/APIs; factual bibliographic metadata, official product descriptions, official cover URLs, purchase links, and source provenance preserved for each field.",
    "takedown_contact": "https://www.andotherstories.org/contact/",
    "excluded_content": [
        "cart_checkout_account",
        "inventory_state",
        "prices",
        "user_reviews",
        "raw_html_without_sanitization"
    ],
    "cover_cache_policy": "cache_allowed",
    "not_legal_advice": "Operator-authorized ingestion policy and provenance metadata; not legal advice.",
    "api": {
        "type": "wordpress",
        "endpoint": "https://www.andotherstories.org",
        "post_type": "product",
        "taxonomy": "product_cat",
        "include_imprints": [
            "books"
        ],
        "fetch_detail_pages": true,
        "detail_path_prefixes": [
            "/"
        ]
    },
    "rate_limit": {
        "max_concurrency": 2,
        "min_delay_ms": 250,
        "max_bytes": 52428800
    },
    "expected_record_count": 190
}
