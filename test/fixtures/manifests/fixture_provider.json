{
  "provider": "fixture_test_provider",
  "name": "Fixture Test Provider",
  "source_mode": "api",
  "source_urls": ["https://fixture.example.com/books"],
  "source_hosts": ["fixture.example.com"],
  "cover_hosts": ["fixture.example.com"],
  "api": {
    "type": "shopify",
    "endpoint": "https://fixture.example.com/api/graphql",
    "auth": {
      "method": "api_key",
      "key_env": "FIXTURE_API_KEY"
    }
  },
  "spider": {},
  "rate_limit": {
    "max_concurrency": 2,
    "min_delay_ms": 500,
    "max_bytes": 10485760
  },
  "expected_record_count": 5,
  "permission_basis": "Test fixture for E2E ingestion pipeline tests — deterministic data.",
  "takedown_contact": "https://fixture.example.com/contact",
  "excluded_content": ["raw_html", "prices", "reviews", "cart_checkout_account"],
  "cover_cache_policy": "cache_allowed",
  "not_legal_advice": true
}
