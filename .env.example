# Hiraeth production environment template.
# Copy values into the deployment secret store; do not commit real secrets.

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=replace-with-generated-secret-key-base

# PostgreSQL connection string for the production database.
DATABASE_URL=postgres://hiraeth_user:replace-with-database-password@postgres:5432/hiraeth_prod

# Public host name used for Phoenix URL generation.
PHX_HOST=hiraeth.example.com

# Scrapling sidecar HTTP endpoint reachable from the Phoenix container.
SCRAPLING_SIDECAR_URL=http://scrapling-sidecar:8000

# Ecto database connection pool size for one application instance.
POOL_SIZE=10

# Common release/runtime settings.
PHX_SERVER=true
PORT=4000
