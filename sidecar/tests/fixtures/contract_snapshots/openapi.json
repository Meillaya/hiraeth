                "type": "null"
              }
            ],
            "title": "Max Bytes"
          },
          "url": {
            "title": "Url",
            "type": "string"
          },
          "vendor": {
            "title": "Vendor",
            "type": "string"
          }
        },
        "required": [
          "url",
          "vendor"
        ],
        "title": "DetailScrapeRequest",
        "type": "object"
      },
      "DetailScrapeResponse": {
        "properties": {
          "contributors": {
            "items": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "title": "Contributors",
            "type": "array"
          },
          "cover": {
            "additionalProperties": {
              "$ref": "#/components/schemas/JsonValue"
            },
            "title": "Cover",
            "type": "object"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "isbn_13": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Isbn 13"
          },
          "published_on": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Published On"
          },
          "source_uri": {
            "title": "Source Uri",
            "type": "string"
          },
          "vendor": {
            "title": "Vendor",
            "type": "string"
          }
        },
        "required": [
          "vendor",
          "source_uri"
        ],
        "title": "DetailScrapeResponse",
        "type": "object"
      },
      "FetchRequest": {
        "properties": {
          "config": {
            "additionalProperties": {
              "$ref": "#/components/schemas/JsonValue"
            },
            "title": "Config",
            "type": "object"
          },
          "provider": {
            "title": "Provider",
            "type": "string"
          }
        },
        "required": [
          "provider"
        ],
        "title": "FetchRequest",
        "type": "object"
      },
      "FetchResponse": {
        "properties": {
          "provider": {
            "title": "Provider",
            "type": "string"
          },
          "records": {
            "items": {
              "additionalProperties": {
                "$ref": "#/components/schemas/JsonValue"
              },
              "type": "object"
            },
            "title": "Records",
            "type": "array"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "provider",
          "status"
