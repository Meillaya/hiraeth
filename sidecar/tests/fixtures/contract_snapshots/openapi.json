        "title": "FetchResponse",
        "type": "object"
      },
      "JsonValue": {},
      "ScrapeRequest": {
        "properties": {
          "config": {
            "additionalProperties": {
              "$ref": "#/components/schemas/JsonValue"
            },
            "title": "Config",
            "type": "object"
          },
          "provider": {
            "title": "Provider",
            "type": "string"
          }
        },
        "required": [
          "provider"
        ],
        "title": "ScrapeRequest",
        "type": "object"
      },
      "ScrapeResponse": {
        "properties": {
          "provider": {
            "title": "Provider",
            "type": "string"
          },
          "records": {
            "items": {
              "additionalProperties": {
                "$ref": "#/components/schemas/JsonValue"
              },
              "type": "object"
            },
            "title": "Records",
            "type": "array"
